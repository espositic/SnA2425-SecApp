<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>SecApp</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>15</session-timeout>
        <tracking-mode>COOKIE</tracking-mode>
        <cookie-config>
            <http-only>true</http-only>
            <!-- <secure>true</secure>  --> <!-- lo abiliteremo quando attiverai HTTPS -->
            <name>JSESSIONID</name>
        </cookie-config>
    </session-config>

    <security-constraint>
        <web-resource-collection>
            <web-resource-name>SecurePages</web-resource-name>
            <url-pattern>/login</url-pattern>
            <url-pattern>/register</url-pattern>
            <url-pattern>/dashboard</url-pattern>
            <url-pattern>/upload</url-pattern>
            <url-pattern>/proposals</url-pattern>
            <url-pattern>/proposal</url-pattern>
        </web-resource-collection>
        <user-data-constraint>
            <transport-guarantee>CONFIDENTIAL</transport-guarantee>
        </user-data-constraint>
    </security-constraint>



    <!-- Sprint 3: qui aggiungeremo il security-constraint CONFIDENTIAL per forzare HTTPS -->
</web-app>
